{
  "name": "arhus-cli",
"version": "0.3.3"
  "description": "local-first security analysis for TypeScript & JavaScript",
  "license": "MIT",
  "keywords": [
    "security",
    "scanner",
    "analysis",
    "typescript",
    "javascript",
    "cli",
    "security-audit",
    "static-analysis",
    "sast",
    "vulnerability"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sudoeren/arhus"
  },
  "bin": {
    "arhus": "./dist/arhus.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "bun build bin/arhus.ts --outdir=dist --target=node",
    "prepublishOnly": "bun run build && bun test",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.5.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ora": "^9.4.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
