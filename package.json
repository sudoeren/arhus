{
  "name": "argus-cli",
  "version": "0.1.0",
  "description": "DevSecOps security scanner — 100% local code analysis with TypeScript AST-based auto-fix",
  "type": "module",
  "bin": {
    "argus": "./bin/argus.ts"
  },
  "files": [
    "bin/",
    "src/",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "bun run index.ts",
    "scan": "bun run bin/argus.ts scan",
    "fix": "bun run bin/argus.ts fix",
    "init": "bun run bin/argus.ts init",
    "build": "bun build bin/argus.ts --outdir=dist --target=node",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
